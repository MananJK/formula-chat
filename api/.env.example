# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# PostgreSQL
# When running via Docker Compose, use the service name "postgres" as the host.
DATABASE_URL=postgresql://f1_user:password@postgres:5433/f1
POSTGRES_PASSWORD=password
DATABASE_QUERY_TIMEOUT=5

# Redis
REDIS_URL=redis://redis:6379/0

# Cache TTLs (seconds)
# How long to cache SQL query results (varies by data type: standings=300, race results=3600, current=60)
SQL_CACHE_TTL=60
# How long to cache embeddings
EMBEDDING_CACHE_TTL=86400

# pgvector RAG
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=5

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:5173","https://yourdomain.com"]
RATE_LIMIT_PER_MINUTE=20

# Environment
ENV=development